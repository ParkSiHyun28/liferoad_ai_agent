# 공급자 선택. 하나만 활성화. 가능: ollama / groq / gemini / claude
# 권장 기본: gemini (무료, 한국어 안정, 카드 불필요)
LLM_PROVIDER=gemini

# --- 무료 로컬 (ollama, 인터넷 불필요) ---
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_BASE_URL=http://localhost:11434/v1

# --- 무료 클라우드 Groq (속도 최강, 키 gsk_로 시작) ---
# 키 발급: https://console.groq.com
# 쓰려면 위 LLM_PROVIDER=groq 로 바꾸고 아래 키 채우기.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- 무료 클라우드 Gemini (한국어 안정, 키 AIza로 시작) ---
# 키 발급: https://aistudio.google.com/apikey
# 쓰려면 위 LLM_PROVIDER=gemini 로 바꾸고 아래 키 채우기.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- 본선용 Claude (유료) ---
# 쓰려면 위 LLM_PROVIDER=claude 로 바꾸고 아래 주석 해제 후 키 채우기.
CLAUDE_MODEL=claude-opus-4-8
# ANTHROPIC_API_KEY=
